---
import Layout from '../layouts/Layout.astro';

type PortfolioItem = {
  title: string;
  year: string;
  description: string;
  technologies: string[];
  url?: string;
  note?: string;
};

const contactLinks = [
  { label: 'GitHub', href: 'https://github.com/unclebobert' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/jfu421' },
  { label: 'Email', href: 'mailto:jacksonfu777@gmail.com' },
];

const skills = [
  'Javascript',
  'Typescript',
  'HTML/CSS',
  'Python',
  'SQL',
  'React',
  'Vite',
  'Astro',
  'Flask',
  'Docker',
];

const projects: PortfolioItem[] = [
  {
    title: 'Connections - Discord Activity',
    year: '2026',
    url: 'https://discord.com/discovery/applications/1506187422281498684',
    description:
      "Unofficial port of the New York Times' popular Connections as a Discord activity.",
    technologies: [
      'Typescript',
      'React',
      'Vite',
      'Cloudflare (Workers, Durable Objects, KV)',
      'Hono',
    ],
  },
  {
    title: 'GreedyPay',
    year: '2025',
    url: 'https://unclebobert.github.io/greedy-pay/',
    description:
      'Fairly simple bill-splitting app. Collates multiple expenses and determines the most convenient way for everyone to be paid in the fewest transactions possible.',
    technologies: ['Typescript', 'React', 'Vite', 'Dexie'],
  },
  {
    title: 'MRI Annotation System',
    year: '2025',
    note: 'UNSW Computer Science Project',
    description:
      'A web based system to allow expert radiologists to easily annotate brain MRIs for potential lacunar infarct candidates, which are provided by a basic AI external to the project. The data from the radiologists can then be used to fine-tune the AI model.',
    technologies: ['Typescript', 'React', 'Vite', 'Docker', 'Python', 'Flask'],
  },
];

const work: PortfolioItem[] = [
  {
    title: 'Tutoring Centre Administration System',
    year: '2023 - Present',
    description:
      'Includes the administrator, staff and student portals of a tutoring centre.',
    technologies: ['Javascript', 'HTML/CSS', 'Python', 'Flask', 'SQL'],
  },
  {
    title: 'Tutoring Centre Website',
    year: '2026',
    note: 'Not currently deployed yet',
    description:
      'Revamp of the user-facing public promotional website that includes several interactive elements such as a course outline viewer.',
    technologies: ['Javascript', 'HTML/CSS', 'React', 'Astro'],
  },
];

const allItems = [...projects, ...work];

const itemUsesSkill = (item: PortfolioItem, skill: string) => {
  return item.technologies.includes(skill);
};

const getRelatedItems = (skill: string) =>
  allItems.filter((item) => itemUsesSkill(item, skill));

const slugify = (value: string) =>
  value
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/(^-|-$)/g, '');
---

<Layout>
  <a class="skip-link" href="#content">Skip to content</a>

  <header class="site-header">
    <nav class="site-nav" aria-label="Page sections">
      <a href="#intro">Intro</a>
      <a href="#skills">Skills</a>
      <a href="#projects">Projects</a>
      <a href="#work">Work</a>
      <a href="#contact">Contact</a>
    </nav>
  </header>

  <main id="content" class="page-shell">
    <header class="intro" id="intro" aria-labelledby="intro-title">
      <h1 id="intro-title">Hi, I'm Jackson</h1>
      <p>
        I'm a full-stack developer currently focused on web development,
        but always looking to explore new things and dreaming up new ideas.
        Sometimes I even get around to finishing them.
      </p>
    </header>

    <section class="section" id="skills" aria-labelledby="skills-title">
      <div class="section-heading">
        <h2 id="skills-title">Skills</h2>
        <p>Click on a technology to see what I've used it for.</p>
      </div>

      <div class="skills-list" aria-label="Skills">
        {
          skills.map((skill) => {
            const relatedItems = getRelatedItems(skill);

            return (
              <details class="skill">
                <summary>{skill}</summary>
                <div class="skill-detail">
                  {relatedItems.length > 0 ? (
                    <ul>
                      {relatedItems.map((item) => (
                        <li>
                          <a href={`#${slugify(item.title)}`}>
                            {item.title}
                          </a>
                        </li>
                      ))}
                    </ul>
                  ) : (
                    <p>No highlighted project yet.</p>
                  )}
                </div>
              </details>
            );
          })
        }
      </div>
    </section>

    <section class="section" id="projects" aria-labelledby="projects-title">
      <div class="section-heading">
        <h2 id="projects-title">Projects</h2>
      </div>

      <div class="item-list">
        {
          projects.map((project) => (
            <article class="item" id={slugify(project.title)}>
              <div class="item-header">
                <h3>
                  {project.url ? (
                    <a href={project.url}>{project.title}</a>
                  ) : (
                    project.title
                  )}
                </h3>
                <span>{project.year}</span>
              </div>
              {project.note && <p class="note">{project.note}</p>}
              <p>{project.description}</p>
              <details class="tech-detail">
                <summary>Technologies</summary>
                <ul class="tech-list">
                  {project.technologies.map((technology) => (
                    <li>{technology}</li>
                  ))}
                </ul>
              </details>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section" id="work" aria-labelledby="work-title">
      <div class="section-heading">
        <h2 id="work-title">Work</h2>
        <p>For more details about these, <a href="#contact">contact me</a>.</p>
      </div>

      <div class="item-list">
        {
          work.map((role) => (
            <article class="item" id={slugify(role.title)}>
              <div class="item-header">
                <h3>{role.title}</h3>
                <span>{role.year}</span>
              </div>
              {role.note && <p class="note">{role.note}</p>}
              <p>{role.description}</p>
              <details class="tech-detail">
                <summary>Technologies</summary>
                <ul class="tech-list">
                  {role.technologies.map((technology) => (
                    <li>{technology}</li>
                  ))}
                </ul>
              </details>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section contact-section" id="contact" aria-labelledby="contact-title">
      <div class="section-heading">
        <h2 id="contact-title">Contact</h2>
      </div>

      <nav class="contact-links" aria-label="Contact links">
        {
          contactLinks.map((link) => (
            <a href={link.href} rel="me">
              {link.label}
            </a>
          ))
        }
      </nav>
    </section>
  </main>
</Layout>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #ffffff;
    --text: #202124;
    --muted: #686f76;
    --faint: #f4f4f2;
    --line: #deded9;
    --link: #0f766e;
    --link-quiet: #5b6564;
    --interactive-hover: #0b5f59;
    --focus: #0f766e;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-width: 320px;
    background: var(--bg);
    color: var(--text);
    font-size: 16px;
    line-height: 1.7;
    text-rendering: optimizeLegibility;
  }

  a {
    color: var(--link);
    text-decoration-color: color-mix(in srgb, var(--link), transparent 54%);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  a:hover {
    text-decoration-color: currentColor;
    color: var(--interactive-hover);
  }

  :focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 4px;
  }

  .skip-link {
    position: fixed;
    left: 1rem;
    top: 1rem;
    z-index: 10;
    padding: 0.4rem 0.65rem;
    background: var(--bg);
    border: 1px solid var(--line);
    color: var(--text);
    transform: translateY(-160%);
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 2;
    border-bottom: 1px solid color-mix(in srgb, var(--line), transparent 30%);
    background: color-mix(in srgb, var(--bg), transparent 8%);
    backdrop-filter: blur(12px);
  }

  .site-nav {
    width: 100%;
    max-width: 720px;
    min-height: 56px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    text-decoration: none;
  }

  .site-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.35rem 1rem;
    font-size: 0.95rem;
  }

  .page-shell {
    width: min(100% - 40px, 720px);
    margin: 0 auto;
    padding: 56px 0 56px;
  }

  .intro {
    display: grid;
    grid-template-columns: 42px 1fr;
    gap: 22px 18px;
    align-items: center;
  }

  .contact-links {
    width: 100%;
    display: flex;
    gap: 0.45rem 1rem;
    align-items: center;
    font-size: 0.95rem;
  }

  .contact-links a:hover {
    color: var(--link);
  }

  h1,
  h2,
  h3,
  p {
    margin: 0;
  }

  h1 {
    grid-column: 1 / -1;
    margin-top: 16px;
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 0.98;
  }

  .intro > p {
    grid-column: 1 / -1;
    max-width: 62ch;
    color: var(--muted);
    font-size: 1.08rem;
  }

  .section {
    margin-top: 68px;
    padding-top: 30px;
    border-top: 1px solid var(--line);
    scroll-margin-top: 76px;
  }

  .intro {
    scroll-margin-top: 76px;
  }

  .section-heading {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 18px;
    margin-bottom: 24px;
  }

  h2 {
    font-size: 1.4rem;
    font-weight: 700;
    line-height: 1.35;
  }

  .section-heading p,
  .note {
    color: var(--muted);
    font-size: 0.94rem;
  }

  .skills-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px 18px;
  }

  details {
    position: relative;
  }

  summary {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    cursor: pointer;
    color: var(--link-quiet);
    list-style: none;
    transition: color 160ms ease;
  }

  summary:hover {
    color: var(--interactive-hover);
  }

  summary::-webkit-details-marker {
    display: none;
  }

  summary::after {
    content: "";
    width: 0.4em;
    height: 0.4em;
    border-right: 1.5px solid currentColor;
    border-bottom: 1.5px solid currentColor;
    opacity: 0.72;
    transform: rotate(45deg) translateY(-0.1em);
    transition:
      opacity 160ms ease,
      transform 180ms ease;
  }

  details[open] > summary {
    color: var(--text);
  }

  details[open] > summary:hover {
    color: var(--interactive-hover);
  }

  details[open] > summary::after {
    opacity: 0.9;
    transform: rotate(225deg) translate(-0.02em, -0.02em);
  }

  details[open] > .skill-detail,
  details[open] > .tech-list {
    animation: disclosure-open 180ms ease-out;
  }

  @keyframes disclosure-open {
    from {
      opacity: 0;
      transform: translateY(-4px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .skill {
    min-height: 32px;
  }

  .skill summary {
    min-height: 32px;
  }

  .skill-detail {
    margin: 3px 0 14px;
    padding-left: 14px;
    border-left: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.94rem;
  }

  .skill-detail ul,
  .tech-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .skill-detail li + li {
    margin-top: 2px;
  }

  .item-list {
    display: grid;
    gap: 34px;
  }

  .item {
    scroll-margin-top: 24px;
  }

  .item-header {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 16px;
    align-items: baseline;
  }

  h3 {
    font-size: 1.08rem;
    font-weight: 650;
    line-height: 1.35;
  }

  h3 a {
    color: inherit;
  }

  .item-header span {
    color: var(--muted);
    font-size: 0.9rem;
    white-space: nowrap;
  }

  .item > p {
    margin-top: 8px;
    max-width: 68ch;
  }

  .tech-detail {
    margin-top: 10px;
  }

  .tech-detail summary {
    min-height: 30px;
    font-size: 0.94rem;
  }

  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 6px;
  }

  .tech-list li {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 2px 9px;
    background: var(--faint);
    color: var(--muted);
    font-size: 0.84rem;
    line-height: 1.7;
  }

  .contact-section {
    padding-bottom: 30px;
    border-bottom: 1px solid var(--line);
  }

  @media (max-width: 640px) {
    body {
      font-size: 15.5px;
    }

    .page-shell {
      width: min(100% - 30px, 720px);
      padding-top: 42px;
    }

    .site-nav {
      min-height: auto;
      padding: 12px 0;
      width: min(100% - 30px, 720px);
      justify-content: flex-end;
      gap: 0.25rem 0.85rem;
    }

    .intro {
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .contact-links {
      gap: 0.35rem 0.8rem;
    }

    h1 {
      margin-top: 12px;
    }

    .section {
      margin-top: 54px;
      scroll-margin-top: 104px;
    }

    .intro {
      scroll-margin-top: 104px;
    }

    .item-header span {
      white-space: normal;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    summary,
    summary::after,
    .site-nav a {
      transition: none;
    }

    details[open] > .skill-detail,
    details[open] > .tech-list {
      animation: none;
    }
  }
</style>
